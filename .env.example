# Copy to .env and fill in real values — never commit .env
DATABASE_URL=postgresql://postgres:password@localhost:5432/slt_ebill
OUTPUT_DIR=./output
LOG_LEVEL=INFO

# Auth — change JWT_SECRET to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Short-lived signed PDF link tokens (itsdangerous)
PDF_TOKEN_SECRET=change-me-pdf-token-secret
PDF_TOKEN_EXPIRE_SECONDS=300
