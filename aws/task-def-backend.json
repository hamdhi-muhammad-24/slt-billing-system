{
  "family": "slt-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::757905896932:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::757905896932:role/slt-task-role",
  "containerDefinitions": [
    {
      "name": "slt-backend",
      "image": "757905896932.dkr.ecr.ap-southeast-1.amazonaws.com/slt-backend:latest",
      "portMappings": [
        { "containerPort": 8000, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "EMAIL_BACKEND",       "value": "ses" },
        { "name": "SMS_BACKEND",         "value": "twilio" },
        { "name": "AWS_REGION",          "value": "ap-southeast-1" },
        { "name": "S3_BUCKET",           "value": "slt-bill-pdfs-prod" },
        { "name": "LOG_LEVEL",           "value": "INFO" },
        { "name": "CORS_ORIGINS",        "value": "[\"https://*\"]" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",        "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:757905896932:secret:slt/database_url" },
        { "name": "JWT_SECRET",          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:757905896932:secret:slt/jwt_secret" },
        { "name": "PDF_TOKEN_SECRET",    "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:757905896932:secret:slt/pdf_token_secret" },
        { "name": "CELERY_BROKER_URL",   "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:757905896932:secret:slt/redis_url" },
        { "name": "CELERY_RESULT_BACKEND","valueFrom": "arn:aws:secretsmanager:ap-southeast-1:757905896932:secret:slt/redis_url_1" },
        { "name": "EMAIL_FROM",          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:757905896932:secret:slt/email_from" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/slt-backend",
          "awslogs-region":        "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}

